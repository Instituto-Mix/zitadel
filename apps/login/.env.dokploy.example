# Runtime env for the forked Login v2 container (Dokploy).
# Copy to your Dokploy service env. Values marked (build-time) are NOT here —
# they are baked via Docker build ARGs (see Dockerfile.dokploy).
#
# Build-time (set as build args, not here):
#   SERVER_ACTION_ALLOWED_ORIGINS=entrar.institutomix.com.br   # the domain (default)
#   NEXT_PUBLIC_BASE_PATH=                                       # empty => served at root

# --- Zitadel connection (required) ---
# Base URL of the Zitadel API/issuer this login app talks to.
ZITADEL_API_URL=https://your-zitadel-instance.example.com
# Service user PAT with the login client permissions. Prefer a file mount +
# ZITADEL_SERVICE_USER_TOKEN_FILE in production; the raw token also works:
ZITADEL_SERVICE_USER_TOKEN=

# --- Track B: legacy-identifier resolver (this fork's feature) ---
# Backend that translates a typed tax number / legacy username into the
# canonical Zitadel loginName. If unset, resolution is skipped and login works
# normally with real loginNames (fail-open).
# Include the API version prefix; the app POSTs to {AUTH_BACKEND_URL}/auth/resolve.
AUTH_BACKEND_URL=https://your-auth-backend.example.com/v1
# Token the backend's guard checks. Sent as the `x-zitadel-service-account`
# header (NOT Authorization: Bearer).
AUTH_BACKEND_TOKEN=

# --- Optional ---
EMAIL_VERIFICATION=false
# Disable the OpenTelemetry Node SDK unless you run a collector.
OTEL_SDK_DISABLED=true
# CSP iframe origins are fetched from Zitadel; set false to skip that fetch.
# CSP_FETCH_ENABLED=false
